# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# LLM provider abstraction — 'openrouter' | 'anthropic' | 'deepseek'
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Fast, non-reasoning model used only for the query-rewrite step (lib/rag/rewriteQuery.ts).
# Keep this separate from OPENROUTER_MODEL, which may be a slower "reasoning" model.
OPENROUTER_REWRITE_MODEL=poolside/laguna-m.1:free
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Fast Anthropic model for the query-rewrite step; leave unset to default to a Haiku-class model.
ANTHROPIC_REWRITE_MODEL=claude-haiku-4-5
# DeepSeek API key from platform.deepseek.com directly (not via OpenRouter).
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
# deepseek-v4-flash's "thinking" mode is slow chain-of-thought, so the
# non-thinking default is used for the rewrite step too. deepseek-chat /
# deepseek-reasoner (old model ids) are deprecated 2026-07-24.
DEEPSEEK_REWRITE_MODEL=deepseek-v4-flash

# İstəyə bağlı: OpenRouter-in pulsuz gündəlik limitinə düşəndə avtomatik fallback
# (yalnız LLM_PROVIDER=openrouter üçün — LLM_PROVIDER=anthropic-də təsiri yoxdur).
# Google-un öz Gemini API-si istifadə olunur (OpenRouter-dəki Gemini yox —
# o, eyni OpenRouter kvotasını paylaşır və müstəqil tutum vermir).
#
# DİQQƏT: GOOGLE_GENERATIVE_AI_API_KEY həm də EMBEDDING üçün istifadə olunur
# (lib/embeddings/gemini.ts, gemini-embedding-001, 1536 ölçü) — yalnız chat
# fallback/vision üçün deyil. Embedding provayderi LLM_PROVIDER-dən TAMAMİLƏ
# ayrı bir oxdur: hansı modelin işlədiyini app_settings-dəki
# `active_embedding_model` açarı ('local' | 'gemini', default 'local')
# müəyyən edir və admin paneldən dəyişdirilir — env dəyişəni ilə yox.
# Bu açar yalnız `chunks.embedding_gemini` əhatəsi 100% olduqda 'gemini'-yə
# keçirilə bilər (scripts/backfill-gemini-embeddings.mjs).
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_REWRITE_MODEL=gemini-2.5-flash-lite

# Rate limiting — regular users only, admins are exempt (app/api/chat/route.ts).
# Fixed-window counter (lib/chat/rateLimit.ts, check_chat_rate_limit RPC).
# Ultimate fallback default — the effective global default can also be
# configured at runtime via the app_settings table (see
# app/api/admin/settings/rate-limit/route.ts), which takes precedence over
# this env var when set.
CHAT_RATE_LIMIT_MAX_PER_DAY=20
CHAT_RATE_LIMIT_WINDOW_SECONDS=86400
CHAT_RATE_LIMIT_MIN_SPACING_SECONDS=4

# Feature flags
NEXT_PUBLIC_ADS_ENABLED=false

# Push notifications (Phase 3b) — generate a real keypair with
# `npx web-push generate-vapid-keys` and set the same public key value in
# both VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY (the public key is
# safe to expose client-side for pushManager.subscribe({applicationServerKey})).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
