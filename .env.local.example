# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# LLM provider abstraction — 'openrouter' | 'anthropic' | 'deepseek'
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Fast, non-reasoning model used only for the query-rewrite step (lib/rag/rewriteQuery.ts).
# Keep this separate from OPENROUTER_MODEL, which may be a slower "reasoning" model.
OPENROUTER_REWRITE_MODEL=poolside/laguna-m.1:free
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Fast Anthropic model for the query-rewrite step; leave unset to default to a Haiku-class model.
ANTHROPIC_REWRITE_MODEL=claude-haiku-4-5
# DeepSeek API key from platform.deepseek.com directly (not via OpenRouter).
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
# deepseek-v4-flash's "thinking" mode is slow chain-of-thought, so the
# non-thinking default is used for the rewrite step too. deepseek-chat /
# deepseek-reasoner (old model ids) are deprecated 2026-07-24.
DEEPSEEK_REWRITE_MODEL=deepseek-v4-flash

# İstəyə bağlı: OpenRouter-in pulsuz gündəlik limitinə düşəndə avtomatik fallback
# (yalnız LLM_PROVIDER=openrouter üçün — LLM_PROVIDER=anthropic-də təsiri yoxdur).
# Google-un öz Gemini API-si istifadə olunur (OpenRouter-dəki Gemini yox —
# o, eyni OpenRouter kvotasını paylaşır və müstəqil tutum vermir).
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_REWRITE_MODEL=gemini-2.5-flash-lite

# Feature flags
NEXT_PUBLIC_ADS_ENABLED=false
